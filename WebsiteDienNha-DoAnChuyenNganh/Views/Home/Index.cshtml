@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<WebsiteDienNha_DoAnChuyenNganh.Models.Category> ?? new List<WebsiteDienNha_DoAnChuyenNganh.Models.Category>();
    var featuredProducts = ViewBag.FeaturedProducts as List<WebsiteDienNha_DoAnChuyenNganh.Models.Product> ?? new List<WebsiteDienNha_DoAnChuyenNganh.Models.Product>();
    var bestSellingProducts = ViewBag.BestSellingProducts as List<WebsiteDienNha_DoAnChuyenNganh.Models.Product> ?? new List<WebsiteDienNha_DoAnChuyenNganh.Models.Product>();
}

<!-- Hero Banner Section -->
<section class="hero-banner">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="hero-slide" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="container">
                        <div class="row align-items-center min-vh-50">
                            <div class="col-lg-6">
                                <div class="hero-content">
                                    <h1 class="hero-title">Thiết bị điện chính hãng</h1>
                                    <p class="hero-subtitle">Chất lượng cao, giá cả hợp lý, giao hàng nhanh chóng</p>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-hero">
                                        <i class="bi bi-arrow-right me-2"></i>Mua ngay
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-6 text-center">
                                <div class="hero-image">
                                    <i class="bi bi-lightning-charge-fill"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="hero-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <div class="container">
                        <div class="row align-items-center min-vh-50">
                            <div class="col-lg-6">
                                <div class="hero-content">
                                    <h1 class="hero-title">Giảm giá lên đến 30%</h1>
                                    <p class="hero-subtitle">Khuyến mãi đặc biệt cho khách hàng mới</p>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-hero">
                                        <i class="bi bi-tag me-2"></i>Xem khuyến mãi
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-6 text-center">
                                <div class="hero-image">
                                    <i class="bi bi-gift-fill"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</section>

<!-- Categories Section -->
@if (categories.Any())
{
    <section class="categories-section py-5">
        <div class="container">
            <div class="section-header text-center mb-5">
                <h2 class="section-title">Danh mục sản phẩm</h2>
                <p class="section-subtitle">Khám phá các danh mục sản phẩm phong phú</p>
            </div>
            <div class="row g-4">
                @foreach (var category in categories.Take(8))
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id" class="category-card">
                            <div class="category-icon">
                                <i class="bi bi-grid-3x3-gap"></i>
                            </div>
                            <h5 class="category-name">@category.Name</h5>
                            <span class="category-link">Xem sản phẩm <i class="bi bi-arrow-right"></i></span>
                        </a>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-right-circle me-2"></i>Xem tất cả danh mục
                </a>
            </div>
        </div>
    </section>
}

<!-- Featured Products Section -->
@if (featuredProducts.Any())
{
    <section class="products-section py-5 bg-light">
        <div class="container">
            <div class="section-header text-center mb-5">
                <h2 class="section-title">Sản phẩm nổi bật</h2>
                <p class="section-subtitle">Những sản phẩm được yêu thích nhất</p>
            </div>
            <div class="row g-4">
                @foreach (var product in featuredProducts.Take(8))
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="product-image-wrapper">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" class="product-image">
                                }
                                else
                                {
                                    <div class="product-image-placeholder">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                                <div class="product-overlay">
                                    <span class="btn btn-sm btn-primary">Xem chi tiết</span>
                                </div>
                            </a>
                            <div class="product-info">
                                <h6 class="product-name">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">@product.Name</a>
                                </h6>
                                @{
                                    var promotionPrice = WebsiteDienNha_DoAnChuyenNganh.Utils.ProductHelper.GetPromotionPrice(product);
                                    var hasPromotion = WebsiteDienNha_DoAnChuyenNganh.Utils.ProductHelper.HasActivePromotion(product);
                                    var discountPercent = WebsiteDienNha_DoAnChuyenNganh.Utils.ProductHelper.GetDiscountPercent(product);
                                }
                                <div class="product-price">
                                    @if (hasPromotion && promotionPrice < product.Price)
                                    {
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="promotion-price text-danger fw-bold">@promotionPrice.ToString("N0") đ</span>
                                            <span class="original-price text-muted text-decoration-line-through">@product.Price.ToString("N0") đ</span>
                                            <span class="discount-badge badge bg-danger">-@discountPercent%</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>@product.Price.ToString("N0") đ</span>
                                    }
                                </div>
                                <div class="product-actions">
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <form asp-area="Customer" asp-controller="ShoppingCart" asp-action="Add" method="post" class="d-inline w-100">
                                            <input type="hidden" name="productId" value="@product.Id">
                                            <input type="hidden" name="quantity" value="1">
                                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                                <i class="bi bi-cart-plus me-1"></i>Thêm vào giỏ
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary w-100">
                                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập để mua
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-arrow-right-circle me-2"></i>Xem tất cả sản phẩm
                </a>
            </div>
        </div>
    </section>
}

