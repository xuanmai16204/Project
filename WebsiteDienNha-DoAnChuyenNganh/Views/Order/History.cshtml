@model IEnumerable<WebsiteDienNha_DoAnChuyenNganh.Models.Order>
@{
	ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="order-history-page">
	<div class="container">
	<!-- Page Header -->
	<div class="row mb-4">
		<div class="col-12">
			<div class="d-flex align-items-center gap-3 mb-3">
				<div class="page-header-icon">
					<i class="bi bi-clock-history"></i>
				</div>
				<div>
					<h1 class="fw-bold mb-2 display-6">
						Lịch sử đơn hàng
					</h1>
					<p class="text-muted mb-0">Xem và theo dõi tất cả đơn hàng của bạn</p>
				</div>
			</div>
		</div>
	</div>

	@if (!Model.Any())
	{
		<div class="card shadow-lg border-0 text-center py-5 empty-orders-card">
			<div class="card-body py-5">
				<div class="empty-orders-icon mb-4">
					<i class="bi bi-inbox"></i>
				</div>
				<h4 class="mt-3 mb-3 fw-bold text-dark">Bạn chưa có đơn hàng nào</h4>
				<p class="text-muted mb-4 fs-5">Hãy bắt đầu mua sắm để xem lịch sử đơn hàng của bạn</p>
				<a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5">
					<i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
				</a>
			</div>
		</div>
	}
	else
	{
		<!-- Desktop Table View -->
		<div class="card shadow-lg border-0 d-none d-md-block orders-table-card">
			<div class="card-header bg-primary bg-gradient text-white py-3">
				<h5 class="mb-0 fw-semibold">
					<i class="bi bi-list-ul me-2"></i>Danh sách đơn hàng (@Model.Count() đơn)
				</h5>
			</div>
			<div class="card-body p-0">
				<div class="table-wrapper">
					<table class="table table-hover align-middle mb-0">
						<thead class="table-light">
							<tr>
								<th class="ps-4" style="width: 12%;">Mã đơn</th>
								<th style="width: 18%;">Ngày đặt</th>
								<th class="text-end" style="width: 18%;">Tổng tiền</th>
								<th style="width: 22%;">Trạng thái</th>
								<th class="text-center pe-4" style="width: 30%;">Thao tác</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var order in Model)
							{
								<tr class="order-row">
									<td class="ps-4">
										<strong class="order-id-badge">#@order.Id</strong>
									</td>
									<td>
										<div class="order-date-info">
											<i class="bi bi-calendar3 me-1 text-muted"></i>
											<span class="text-dark">@order.OrderDate.ToString("dd/MM/yyyy")</span>
										</div>
										<small class="text-muted d-block">
											<i class="bi bi-clock me-1"></i>@order.OrderDate.ToString("HH:mm")
										</small>
									</td>
									<td class="text-end">
										<strong class="order-total-amount">@order.Total.ToString("N0") đ</strong>
									</td>
									<td>
										@{
											var statusClass = order.Status == "Paid" || order.Status == "Confirmed" 
												? "status-success" 
												: order.Status == "Failed" || order.Status == "Cancelled" 
												? "status-danger" 
												: "status-warning";
											var statusText = order.Status == "Paid" ? "Đã thanh toán" 
												: order.Status == "Confirmed" ? "Đã xác nhận" 
												: order.Status == "Failed" ? "Thất bại" 
												: order.Status == "Cancelled" ? "Đã hủy" 
												: "Đang xử lý";
										}
										<span class="status-badge @statusClass">
											<i class="bi @(order.Status == "Paid" || order.Status == "Confirmed" ? "bi-check-circle" : order.Status == "Failed" || order.Status == "Cancelled" ? "bi-x-circle" : "bi-clock-history") me-1"></i>
											@statusText
										</span>
									</td>
									<td class="text-center pe-4">
										<a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-primary rounded-pill px-3 order-detail-btn">
											<i class="bi bi-eye me-1"></i>Chi tiết
										</a>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<!-- Mobile Card View -->
		<div class="d-md-none">
			@foreach (var order in Model)
			{
				<div class="card shadow-sm border-0 mb-3 order-card-mobile">
					<div class="card-body p-3">
						<div class="d-flex justify-content-between align-items-start mb-3">
							<div>
								<strong class="order-id-badge-mobile d-block mb-2">#@order.Id</strong>
								<div class="order-date-info-mobile">
									<i class="bi bi-calendar3 me-1 text-muted"></i>
									<span class="text-dark">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
								</div>
							</div>
							@{
								var statusClass = order.Status == "Paid" || order.Status == "Confirmed" 
									? "status-success" 
									: order.Status == "Failed" || order.Status == "Cancelled" 
									? "status-danger" 
									: "status-warning";
								var statusText = order.Status == "Paid" ? "Đã thanh toán" 
									: order.Status == "Confirmed" ? "Đã xác nhận" 
									: order.Status == "Failed" ? "Thất bại" 
									: order.Status == "Cancelled" ? "Đã hủy" 
									: "Đang xử lý";
							}
							<span class="status-badge @statusClass">
								<i class="bi @(order.Status == "Paid" || order.Status == "Confirmed" ? "bi-check-circle" : order.Status == "Failed" || order.Status == "Cancelled" ? "bi-x-circle" : "bi-clock-history") me-1"></i>
								@statusText
							</span>
						</div>
						<hr class="my-3">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<span class="text-muted small d-block mb-1">Tổng tiền</span>
								<strong class="order-total-amount-mobile">@order.Total.ToString("N0") đ</strong>
							</div>
							<a asp-action="Details" asp-route-id="@order.Id" class="btn btn-primary rounded-pill px-4 order-detail-btn">
								<i class="bi bi-eye me-1"></i>Chi tiết
							</a>
						</div>
					</div>
				</div>
			}
		</div>
	}
	</div>
</div>

<style>
	/* Page Container */
	.order-history-page {
		background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
		min-height: calc(100vh - 200px);
		padding: 2rem 0;
	}

	/* Page Header */
	.page-header-icon {
		width: 70px;
		height: 70px;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 2rem;
		box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
		transition: all 0.3s ease;
	}

	.page-header-icon:hover {
		transform: translateY(-3px) scale(1.05);
		box-shadow: 0 8px 24px rgba(102, 126, 234, 0.5);
	}

	/* Empty State */
	.empty-orders-card {
		border-radius: 1.5rem;
		background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
		border: 2px solid rgba(102, 126, 234, 0.1);
		box-shadow: 0 8px 24px rgba(0,0,0,0.08);
		overflow: hidden;
	}

	.empty-orders-icon {
		font-size: 8rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: float 3s ease-in-out infinite;
		opacity: 0.3;
	}

	@@keyframes float {
		0%, 100% { transform: translateY(0px) rotate(0deg); }
		50% { transform: translateY(-20px) rotate(5deg); }
	}

	/* Orders Table Card */
	.orders-table-card {
		border-radius: 1.25rem;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(0,0,0,0.08);
		transition: all 0.3s ease;
	}

	.orders-table-card:hover {
		box-shadow: 0 8px 30px rgba(0,0,0,0.12);
	}

	.orders-table-card .card-header {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border: none;
		padding: 1.25rem 1.5rem;
	}

	.orders-table-card .card-header h5 {
		font-size: 1.1rem;
		letter-spacing: 0.5px;
	}

	.order-row {
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border-bottom: 1px solid rgba(0,0,0,0.05);
	}

	.order-row:hover {
		background: linear-gradient(90deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
		transform: translateX(4px);
		box-shadow: 0 2px 8px rgba(102, 126, 234, 0.1);
	}

	.order-id-badge {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		padding: 0.625rem 1.25rem;
		border-radius: 0.75rem;
		font-size: 1.05rem;
		font-weight: 700;
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
		display: inline-block;
		transition: all 0.3s ease;
		letter-spacing: 0.5px;
	}

	.order-id-badge:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(102, 126, 234, 0.5);
	}

	.order-id-badge-mobile {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		padding: 0.625rem 1.25rem;
		border-radius: 0.75rem;
		font-size: 1.15rem;
		font-weight: 700;
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
		display: inline-block;
		letter-spacing: 0.5px;
	}

	.order-date-info {
		color: #212529;
		font-weight: 500;
	}

	.order-date-info-mobile {
		color: #212529;
		font-size: 0.9rem;
	}

	.order-total-amount {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: 0.5px;
	}

	.order-total-amount-mobile {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 0.5px;
	}

	/* Status Badges */
	.status-badge {
		padding: 0.625rem 1.25rem;
		border-radius: 0.75rem;
		font-size: 0.9rem;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		white-space: nowrap;
		transition: all 0.3s ease;
		letter-spacing: 0.3px;
	}

	.status-badge:hover {
		transform: translateY(-2px);
	}

	.status-success {
		background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
		color: white;
		box-shadow: 0 4px 12px rgba(40, 167, 69, 0.4);
	}

	.status-success:hover {
		box-shadow: 0 6px 16px rgba(40, 167, 69, 0.5);
	}

	.status-danger {
		background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
		color: white;
		box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
	}

	.status-danger:hover {
		box-shadow: 0 6px 16px rgba(220, 53, 69, 0.5);
	}

	.status-warning {
		background: linear-gradient(135deg, #ffc107 0%, #ffb300 100%);
		color: #212529;
		box-shadow: 0 4px 12px rgba(255, 193, 7, 0.4);
	}

	.status-warning:hover {
		box-shadow: 0 6px 16px rgba(255, 193, 7, 0.5);
	}

	.order-detail-btn {
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		font-weight: 600;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border: none;
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
	}

	.order-detail-btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
		background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
	}

	.order-detail-btn:active {
		transform: translateY(-1px);
	}

	/* Mobile Card */
	.order-card-mobile {
		border-radius: 1.25rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid rgba(102, 126, 234, 0.1);
		background: white;
		overflow: hidden;
	}

	.order-card-mobile:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(102, 126, 234, 0.15) !important;
		border-color: rgba(102, 126, 234, 0.3);
	}

	.order-card-mobile .card-body {
		background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
	}

	/* Table Improvements */
	.table-wrapper {
		width: 100%;
		overflow-x: visible;
	}

	.orders-table-card .table {
		width: 100%;
		table-layout: fixed;
		margin: 0;
	}

	.orders-table-card .table thead th {
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		font-size: 0.85rem;
		color: white;
		border: none;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.orders-table-card .table tbody td {
		vertical-align: middle;
		padding: 1.25rem 1rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.orders-table-card .table tbody td:first-child,
	.orders-table-card .table tbody td:last-child {
		white-space: normal;
	}

	/* Responsive Adjustments */
	@@media (max-width: 991.98px) {
		.order-history-page {
			padding: 1.5rem 0;
		}

		.page-header-icon {
			width: 60px;
			height: 60px;
			font-size: 1.75rem;
		}

		.orders-table-card .table thead th {
			font-size: 0.8rem;
			padding: 0.875rem 0.75rem;
		}

		.orders-table-card .table tbody td {
			padding: 1rem 0.75rem;
			font-size: 0.9rem;
		}
	}

	@@media (max-width: 767.98px) {
		.order-history-page {
			padding: 1rem 0;
		}

		.empty-orders-icon {
			font-size: 6rem;
		}

		.order-card-mobile .card-body {
			padding: 1.25rem;
		}

		.order-id-badge-mobile {
			font-size: 1rem;
			padding: 0.5rem 1rem;
		}

		.order-total-amount-mobile {
			font-size: 1.25rem;
		}

		.status-badge {
			font-size: 0.8rem;
			padding: 0.5rem 1rem;
		}
	}

	@@media (max-width: 575.98px) {
		.page-header-icon {
			width: 55px;
			height: 55px;
			font-size: 1.5rem;
		}

		.display-6 {
			font-size: 1.5rem;
		}

		.order-card-mobile .card-body {
			padding: 1rem;
		}

		.order-detail-btn {
			font-size: 0.875rem;
			padding: 0.5rem 1rem;
		}
	}
</style>

