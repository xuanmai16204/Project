@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject SignInManager<WebsiteDienNha_DoAnChuyenNganh.Models.ApplicationUser> SignInManager
@inject UserManager<WebsiteDienNha_DoAnChuyenNganh.Models.ApplicationUser> UserManager
@inject WebsiteDienNha_DoAnChuyenNganh.Data.ApplicationDbContext DbContext
@inject WebsiteDienNha_DoAnChuyenNganh.Services.CartService CartService

@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    WebsiteDienNha_DoAnChuyenNganh.Models.ApplicationUser? currentUser = null;
    if (isSignedIn)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
    var loyaltyLevel = currentUser?.LoyaltyLevel?.Name ?? "Khách thân thiết";
    var loyaltyPoints = currentUser?.LoyaltyPoints ?? 0;
    
    // Load cart count
    var cartCount = 0;
    try
    {
        var cartItems = CartService.GetCart();
        cartCount = cartItems.Sum(i => i.Quantity);
    }
    catch { }
    
    // Load categories for menu
    var categories = new List<WebsiteDienNha_DoAnChuyenNganh.Models.Category>();
    try
    {
        categories = await DbContext.Categories
            .Where(c => c.IsActive)
            .OrderBy(c => c.Name)
            .Take(10)
            .ToListAsync();
    }
    catch { }
}

<!-- Top Utility Bar -->
<div class="top-utility-bar">
    <div class="container-fluid">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-2 py-2">
            <div class="d-flex flex-wrap align-items-center gap-3 text-white-50 small">
                <span><i class="bi bi-telephone-outbound me-1 text-white"></i>Hotline: <a class="text-white text-decoration-none fw-semibold" href="tel:0888666888">0888 66 88</a></span>
            <span class="d-none d-md-inline">|</span>
            <span><i class="bi bi-envelope-open me-1 text-white"></i>support@diennha.vn</span>
            <span class="d-none d-xl-inline">|</span>
                <span><i class="bi bi-clock me-1 text-white"></i>Giờ làm việc: 8:00 - 22:00</span>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
            @if (isSignedIn && currentUser is not null)
            {
                <span class="status-chip bg-gradient-primary">
                    <i class="bi bi-lightning-charge me-1"></i>@loyaltyLevel
                </span>
                <span class="status-chip">
                    <i class="bi bi-stars me-1 text-warning"></i>@loyaltyPoints.ToString("N0") điểm
                </span>
            }
            </div>
        </div>
    </div>
</div>

<!-- Main Header -->
<header class="main-header">
        <div class="container-fluid px-3 px-md-4">
        <div class="header-content">
            <!-- Logo Section -->
            <div class="header-logo">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="logo-wrapper">
                        <span class="logo-icon">⚡</span>
                    </div>
                    <div class="logo-text">
                        <span class="logo-name">Điện Nhà</span>
                        <span class="logo-tagline">Thiết bị điện chính hãng</span>
                    </div>
                </a>
            </div>

            <!-- Search Bar Section -->
            <div class="header-search">
                <form asp-controller="Product" asp-action="Index" method="get" class="search-form">
                    <div class="search-wrapper">
                        <input type="text" 
                               name="search" 
                               class="search-input" 
                               placeholder="Tìm kiếm sản phẩm, thương hiệu..." 
                               autocomplete="off">
                        <button type="submit" class="search-button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    <div class="search-suggestions" id="searchSuggestions" style="display: none;"></div>
                </form>
            </div>

            <!-- Action Icons Section -->
            <div class="header-actions">
                @if (isSignedIn)
                {
                    <!-- Cart Icon -->
                    <a asp-area="Customer" asp-controller="ShoppingCart" asp-action="Index" class="action-icon cart-icon" title="Giỏ hàng">
                        <i class="bi bi-cart3"></i>
                        @if (cartCount > 0)
                        {
                            <span class="action-badge">@cartCount</span>
                        }
                    </a>

                    <!-- User Menu -->
                    <div class="action-icon user-menu-wrapper">
                        <a href="#" class="user-menu-trigger" id="userMenuTrigger" title="Tài khoản">
                            <i class="bi bi-person-circle"></i>
                        </a>
                        <div class="user-menu-dropdown" id="userMenuDropdown">
                            <div class="user-menu-header">
                                <div class="user-avatar">
                                    <i class="bi bi-person-circle"></i>
                                </div>
                                <div class="user-info">
                                    <div class="user-name">@UserManager.GetUserName(User)</div>
                                    <div class="user-level">@loyaltyLevel</div>
                                </div>
                            </div>
                            <div class="user-menu-divider"></div>
                            <a class="user-menu-item" asp-area="" asp-controller="Order" asp-action="History">
                                <i class="bi bi-clock-history"></i>
                                <span>Lịch sử đơn hàng</span>
                            </a>
                            <a class="user-menu-item" asp-area="Customer" asp-controller="Notification" asp-action="Index">
                                <i class="bi bi-bell"></i>
                                <span>Thông báo</span>
                            </a>
                            <a class="user-menu-item" asp-area="Customer" asp-controller="Comparison" asp-action="Index">
                                <i class="bi bi-arrow-left-right"></i>
                                <span>So sánh sản phẩm</span>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="user-menu-divider"></div>
                                <a class="user-menu-item" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i>
                                    <span>Quản trị</span>
                                </a>
                            }
                            <div class="user-menu-divider"></div>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="user-menu-item logout-item">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Đăng xuất</span>
                                </button>
                            </form>
                        </div>
                </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="action-icon login-icon" title="Đăng nhập">
                        <i class="bi bi-box-arrow-in-right"></i>
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="register-btn">
                        <i class="bi bi-person-plus me-2"></i>
                        <span>Đăng ký</span>
                    </a>
                }
            </div>

            <!-- Mobile Menu Toggle -->
            <button class="mobile-menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <!-- Navigation Menu -->
        <nav class="main-nav">
            <div class="nav-container">
                <ul class="nav-menu">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i>
                            <span>Trang chủ</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <ul class="dropdown-menu mega-menu" aria-labelledby="categoriesDropdown">
                            <div class="mega-menu-content">
                                @foreach (var category in categories)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id">
                                            <i class="bi bi-circle-fill me-2"></i>@category.Name
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item fw-bold" asp-controller="Product" asp-action="Index">
                                        <i class="bi bi-arrow-right-circle me-2"></i>Xem tất cả
                                    </a>
                                </li>
                            </div>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-box-seam"></i>
                            <span>Sản phẩm</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Customer" asp-controller="ShoppingCart" asp-action="Index">
                            <i class="bi bi-cart"></i>
                            <span>Giỏ hàng</span>
                            @if (cartCount > 0)
                            {
                                <span class="nav-badge">@cartCount</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Customer" asp-controller="Comparison" asp-action="Index">
                            <i class="bi bi-arrow-left-right"></i>
                            <span>So sánh</span>
                        </a>
                    </li>
                    @if (isSignedIn)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Order" asp-action="History">
                                <i class="bi bi-clock-history"></i>
                                <span>Đơn hàng</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>

        <!-- Mobile Menu -->
        <div class="collapse mobile-menu" id="mobileMenu">
            <ul class="mobile-menu-list">
                <li><a asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i>Trang chủ</a></li>
                <li><a asp-area="" asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam"></i>Sản phẩm</a></li>
                <li><a asp-area="Customer" asp-controller="ShoppingCart" asp-action="Index"><i class="bi bi-cart"></i>Giỏ hàng</a></li>
                <li><a asp-area="Customer" asp-controller="Comparison" asp-action="Index"><i class="bi bi-arrow-left-right"></i>So sánh</a></li>
                @if (isSignedIn)
                {
                    <li><a asp-area="" asp-controller="Order" asp-action="History"><i class="bi bi-clock-history"></i>Đơn hàng</a></li>
                }
            </ul>
        </div>
    </div>
</header>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // User menu toggle
        const userMenuTrigger = document.getElementById('userMenuTrigger');
        const userMenuDropdown = document.getElementById('userMenuDropdown');
        
        if (userMenuTrigger && userMenuDropdown) {
            userMenuTrigger.addEventListener('click', function(e) {
                e.preventDefault();
                userMenuDropdown.classList.toggle('show');
            });
            
            // Close menu when clicking outside
            document.addEventListener('click', function(e) {
                if (!userMenuTrigger.contains(e.target) && !userMenuDropdown.contains(e.target)) {
                    userMenuDropdown.classList.remove('show');
                }
            });
        }

        // Search suggestions (simple implementation)
        const searchInput = document.querySelector('.search-input');
        const searchSuggestions = document.getElementById('searchSuggestions');
        
        if (searchInput && searchSuggestions) {
            let searchTimeout;
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const query = this.value.trim();
                
                if (query.length >= 2) {
                    searchTimeout = setTimeout(function() {
                        // Load suggestions via AJAX
                        $.ajax({
                            url: '@Url.Action("SearchSuggestions", "Product")',
                            type: 'GET',
                            data: { query: query },
                            success: function(data) {
                                if (data && data.length > 0) {
                                    let html = '<div class="suggestions-list">';
                                    data.forEach(function(item) {
                                        html += `<a href="/Product/Details/${item.id}" class="suggestion-item">
                                                    <i class="bi bi-search me-2"></i>
                                                    <span>${item.name}</span>
                                                 </a>`;
                                    });
                                    html += '</div>';
                                    searchSuggestions.innerHTML = html;
                                    searchSuggestions.style.display = 'block';
                                } else {
                                    searchSuggestions.style.display = 'none';
                                }
                            }
                        });
                    }, 300);
                } else {
                    searchSuggestions.style.display = 'none';
                }
            });
            
            // Hide suggestions when clicking outside
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !searchSuggestions.contains(e.target)) {
                    searchSuggestions.style.display = 'none';
                }
            });
        }

        // Active nav link
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = (link.getAttribute('href') || '').toLowerCase();
            if (href && currentPath.startsWith(href) && href !== '#') {
                link.classList.add('active');
            }
        });

        // Load comparison count
        loadComparisonCount();
    });

    function loadComparisonCount() {
        $.ajax({
            url: '@Url.Action("GetCount", "Comparison", new { area = "Customer" })',
            type: 'GET',
            success: function (response) {
                updateComparisonBadge(response.count);
            }
        });
    }

    function updateComparisonBadge(count) {
        var $badge = $('.comparison-badge');
        if (count > 0) {
            $badge.text(count).show();
        } else {
            $badge.hide();
        }
    }
</script>

