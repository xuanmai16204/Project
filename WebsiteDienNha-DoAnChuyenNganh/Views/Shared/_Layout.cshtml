<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebsiteDienNha_DoAnChuyenNganh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebsiteDienNha_DoAnChuyenNganh.styles.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_Header")
    @{
        var isHomePage = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && 
                        ViewContext.RouteData.Values["action"]?.ToString() == "Index";
    }
    @if (isHomePage)
    {
        <main role="main" style="margin-top: calc(40px + 100px + 50px);">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container" style="margin-top: calc(40px + 100px + 50px);">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    @await Html.PartialAsync("_Footer")
    @await Html.PartialAsync("_ChatbotWidget")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
