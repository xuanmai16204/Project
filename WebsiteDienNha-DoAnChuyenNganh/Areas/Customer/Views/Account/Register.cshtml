@model WebsiteDienNha_DoAnChuyenNganh.Areas.Customer.Controllers.RegisterViewModel
@{
	ViewData["Title"] = "Đăng ký";
}

<div class="container my-5">
	<div class="row justify-content-center align-items-center min-vh-50">
		<div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
			<div class="card shadow-lg border-0 rounded-4">
				<div class="card-body p-4 p-md-5">
					<div class="text-center mb-4">
						<i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i>
						<h2 class="mt-3 mb-2 fw-bold">Đăng ký</h2>
						<p class="text-muted small">Tạo tài khoản mới để bắt đầu</p>
					</div>
					<form asp-area="Customer" asp-action="Register" method="post">
						<input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
						<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
						<div class="mb-3">
							<label asp-for="PhoneNumber" class="form-label fw-semibold">
								<i class="bi bi-telephone me-2"></i>Số điện thoại <span class="text-danger">*</span>
							</label>
							<div class="input-group">
								<input asp-for="PhoneNumber" id="phoneNumber" class="form-control form-control-lg" placeholder="Nhập số điện thoại của bạn" type="tel" />
								<button type="button" class="btn btn-outline-primary" id="btnSendOtp">
									<i class="bi bi-send me-1"></i>Gửi OTP
								</button>
							</div>
							<span asp-validation-for="PhoneNumber" class="text-danger small"></span>
							<div id="otpMessage" class="mt-2"></div>
						</div>
						
						<div class="mb-3" id="otpSection" style="display: none;">
							<label asp-for="OtpCode" class="form-label fw-semibold">
								<i class="bi bi-shield-check me-2"></i>Mã OTP <span class="text-muted small">(tùy chọn)</span>
							</label>
							<div class="input-group">
								<input asp-for="OtpCode" id="otpCode" class="form-control form-control-lg" placeholder="Nhập mã OTP 6 chữ số (không bắt buộc)" maxlength="6" />
								<button type="button" class="btn btn-outline-secondary" id="btnResendOtp">
									<i class="bi bi-arrow-clockwise me-1"></i>Gửi lại
								</button>
							</div>
							<span asp-validation-for="OtpCode" class="text-danger small"></span>
							<small class="text-muted d-block mt-1">Mã OTP đã được gửi đến số điện thoại của bạn. Mã có hiệu lực trong 5 phút. Bạn có thể bỏ qua bước này.</small>
						</div>
						<div class="mb-3">
							<label asp-for="Email" class="form-label fw-semibold">
								<i class="bi bi-envelope me-2"></i>Email (tùy chọn)
							</label>
							<input asp-for="Email" class="form-control form-control-lg" placeholder="Nhập email của bạn (không bắt buộc)" type="email" />
							<span asp-validation-for="Email" class="text-danger small"></span>
						</div>
						<div class="mb-3">
							<label asp-for="Password" class="form-label fw-semibold">
								<i class="bi bi-lock me-2"></i>Mật khẩu
							</label>
							<input asp-for="Password" class="form-control form-control-lg" placeholder="Tối thiểu 6 ký tự" />
							<span asp-validation-for="Password" class="text-danger small"></span>
						</div>
						<div class="mb-4">
							<label asp-for="ConfirmPassword" class="form-label fw-semibold">
								<i class="bi bi-lock-fill me-2"></i>Xác nhận mật khẩu
							</label>
							<input asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Nhập lại mật khẩu" />
							<span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
						</div>
						<button type="submit" class="btn btn-primary btn-lg w-100 mb-3 fw-semibold">
							<i class="bi bi-person-plus me-2"></i>Đăng ký
						</button>

						<div class="text-center">
							<p class="mb-0 small">
								Đã có tài khoản? 
								<a asp-area="Customer" asp-action="Login" class="text-decoration-none fw-semibold">Đăng nhập</a>
							</p>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
		$(document).ready(function() {
			let countdownTimer = null;
			let countdownSeconds = 60;

			function startCountdown() {
				const btn = $('#btnSendOtp, #btnResendOtp');
				btn.prop('disabled', true);
				countdownSeconds = 60;
				
				countdownTimer = setInterval(function() {
					countdownSeconds--;
					btn.html(`<i class="bi bi-clock me-1"></i>Gửi lại (${countdownSeconds}s)`);
					
					if (countdownSeconds <= 0) {
						clearInterval(countdownTimer);
						btn.prop('disabled', false);
						$('#btnSendOtp').html('<i class="bi bi-send me-1"></i>Gửi OTP');
						$('#btnResendOtp').html('<i class="bi bi-arrow-clockwise me-1"></i>Gửi lại');
					}
				}, 1000);
			}

			function sendOtp(phoneNumber, isResend = false) {
				if (!phoneNumber || phoneNumber.trim() === '') {
					showMessage('Vui lòng nhập số điện thoại trước.', 'danger');
					return;
				}

				$.ajax({
					url: '@Url.Action("SendOtp", "Account", new { area = "Customer" })',
					method: 'POST',
					data: { phoneNumber: phoneNumber },
					success: function(response) {
						if (response.success) {
							showMessage(response.message, 'success');
							$('#otpSection').slideDown();
							$('#otpCode').focus();
							startCountdown();
						} else {
							showMessage(response.message, 'danger');
						}
					},
					error: function() {
						showMessage('Có lỗi xảy ra. Vui lòng thử lại sau.', 'danger');
					}
				});
			}

			function showMessage(message, type) {
				const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
				$('#otpMessage').html(`<div class="alert ${alertClass} alert-dismissible fade show" role="alert">
					${message}
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>`);
				
				setTimeout(function() {
					$('#otpMessage').fadeOut();
				}, 5000);
			}

			$('#btnSendOtp').on('click', function() {
				const phoneNumber = $('#phoneNumber').val();
				sendOtp(phoneNumber, false);
			});

			$('#btnResendOtp').on('click', function() {
				const phoneNumber = $('#phoneNumber').val();
				sendOtp(phoneNumber, true);
			});

			// Auto-format phone number
			$('#phoneNumber').on('input', function() {
				let value = $(this).val().replace(/\D/g, '');
				if (value.startsWith('0')) {
					value = '84' + value.substring(1);
				}
				if (!value.startsWith('84')) {
					value = '84' + value;
				}
				// Không tự động format, để user nhập tự do
			});

			// Chỉ cho phép nhập số cho OTP
			$('#otpCode').on('input', function() {
				this.value = this.value.replace(/\D/g, '');
			});
		});
	</script>
}

