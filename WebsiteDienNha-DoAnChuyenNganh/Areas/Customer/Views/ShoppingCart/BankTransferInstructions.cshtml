@{
	ViewData["Title"] = "Hướng dẫn chuyển khoản";
	var orderId = ViewBag.OrderId as int?;
	var amount = ViewBag.Amount as decimal?;
}

<div class="container my-5">
	<div class="row justify-content-center">
		<div class="col-12 col-lg-8">
			<div class="card shadow-lg border-0">
				<div class="card-header bg-info text-white text-center py-4">
					<h3 class="mb-0"><i class="bi bi-bank me-2"></i>Hướng dẫn chuyển khoản</h3>
				</div>
				<div class="card-body p-4">
					@if (orderId.HasValue && amount.HasValue)
					{
						<div class="alert alert-success d-flex align-items-center mb-4" role="alert">
							<i class="bi bi-check-circle-fill me-2 fs-4"></i>
							<div>
								<strong>Đơn hàng #@orderId đã được tạo thành công!</strong>
								<div class="small">Vui lòng chuyển khoản theo thông tin bên dưới để hoàn tất đơn hàng.</div>
							</div>
						</div>

						<div class="mb-4">
							<h5 class="text-primary mb-3"><i class="bi bi-info-circle me-2"></i>Thông tin chuyển khoản</h5>
							<div class="table-responsive">
								<table class="table table-bordered">
									<tbody>
										<tr>
											<th class="bg-light" style="width: 40%;">Ngân hàng</th>
											<td><strong>Vietcombank (VCB)</strong></td>
										</tr>
										<tr>
											<th class="bg-light">Số tài khoản</th>
											<td><strong class="text-primary fs-5">0123456789</strong></td>
										</tr>
										<tr>
											<th class="bg-light">Chủ tài khoản</th>
											<td><strong>CÔNG TY TNHH ĐIỆN NHÀ</strong></td>
										</tr>
										<tr>
											<th class="bg-light">Số tiền cần chuyển</th>
											<td><strong class="text-danger fs-4">@amount.Value.ToString("N0") đ</strong></td>
										</tr>
										<tr>
											<th class="bg-light">Nội dung chuyển khoản</th>
											<td><code class="text-primary fs-6">DH@(orderId.Value)</code></td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						<div class="alert alert-warning mb-4">
							<h6 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Lưu ý quan trọng:</h6>
							<ul class="mb-0 small">
								<li>Vui lòng chuyển khoản đúng số tiền: <strong>@amount.Value.ToString("N0") đ</strong></li>
								<li>Ghi chú nội dung chuyển khoản: <code>DH@(orderId.Value)</code> để chúng tôi có thể xác nhận đơn hàng của bạn</li>
								<li>Đơn hàng sẽ được xử lý sau khi chúng tôi nhận được chuyển khoản (thường trong vòng 1-2 giờ làm việc)</li>
								<li>Bạn sẽ nhận được email xác nhận khi đơn hàng được xử lý</li>
								<li>Nếu có thắc mắc, vui lòng liên hệ hotline: <strong>1900 1234</strong></li>
							</ul>
						</div>

						<div class="d-grid gap-2 d-md-flex justify-content-md-center">
							<a asp-area="" asp-controller="Order" asp-action="Details" asp-route-id="@orderId" class="btn btn-primary btn-lg">
								<i class="bi bi-eye me-2"></i>Xem chi tiết đơn hàng
							</a>
							<a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-lg">
								<i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
							</a>
						</div>
					}
					else
					{
						<div class="alert alert-danger">
							<i class="bi bi-exclamation-circle me-2"></i>Không tìm thấy thông tin đơn hàng.
						</div>
						<div class="text-center">
							<a asp-action="Index" class="btn btn-primary">Quay lại giỏ hàng</a>
						</div>
					}
				</div>
			</div>

			<div class="card shadow-sm border-0 mt-4">
				<div class="card-body">
					<h6 class="mb-3"><i class="bi bi-question-circle me-2 text-primary"></i>Các ngân hàng khác:</h6>
					<div class="row g-3">
						<div class="col-12 col-md-6">
							<div class="p-3 border rounded">
								<strong>Techcombank (TCB)</strong><br>
								<small class="text-muted">STK: 9876543210</small>
							</div>
						</div>
						<div class="col-12 col-md-6">
							<div class="p-3 border rounded">
								<strong>BIDV</strong><br>
								<small class="text-muted">STK: 5555555555</small>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

