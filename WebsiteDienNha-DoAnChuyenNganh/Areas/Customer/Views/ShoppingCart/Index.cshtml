@model IEnumerable<WebsiteDienNha_DoAnChuyenNganh.Models.CartItem>
@{
	ViewData["Title"] = "Giỏ hàng";
	var cartItems = ViewBag.CartItems as List<(WebsiteDienNha_DoAnChuyenNganh.Models.CartItem Item, WebsiteDienNha_DoAnChuyenNganh.Models.Product? Product)>;
	var total = Model.Sum(i => i.UnitPrice * i.Quantity);
	var viewBagCartTotal = ViewBag.CartTotal as decimal? ?? total;
	var viewBagDiscountAmount = ViewBag.DiscountAmount as decimal? ?? 0;
	var viewBagFinalTotal = ViewBag.FinalTotal as decimal? ?? total;
	var viewBagAppliedCode = ViewBag.AppliedDiscountCode as string;
	var hasDiscount = !string.IsNullOrEmpty(viewBagAppliedCode) && viewBagDiscountAmount > 0;
}

<div class="container my-4 my-md-5">
	<!-- Page Header -->
	<div class="row mb-4">
		<div class="col-12">
			<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
				<div>
					<h1 class="fw-bold mb-2 display-6">
						<i class="bi bi-cart-check me-2 text-primary"></i>Giỏ hàng của bạn
					</h1>
					<p class="text-muted mb-0">Quản lý sản phẩm trong giỏ hàng của bạn</p>
				</div>
				@if (Model.Any())
				{
					<div class="d-flex align-items-center gap-2">
						<span class="badge bg-primary bg-gradient fs-6 px-3 py-2">
							<i class="bi bi-box-seam me-1"></i>@Model.Count() sản phẩm
						</span>
					</div>
				}
			</div>
		</div>
	</div>

	<div class="row g-4">
		<!-- Main Content -->
		<div class="col-12 col-lg-8">

			@if (!Model.Any())
			{
				<div class="card shadow-lg border-0 text-center py-5 empty-cart-card">
					<div class="card-body py-5">
						<div class="empty-cart-icon mb-4">
							<i class="bi bi-cart-x"></i>
						</div>
						<h3 class="mt-4 mb-3 fw-bold">Giỏ hàng của bạn đang trống</h3>
						<p class="text-muted mb-4 fs-5">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm</p>
						<a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-5 rounded-pill">
							<i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
						</a>
					</div>
				</div>
			}
			else
			{
				<!-- Desktop Table View -->
				<div class="card shadow-sm border-0 overflow-hidden d-none d-md-block cart-table-card">
					<div class="card-header bg-white border-bottom py-3">
						<h5 class="mb-0 fw-semibold">
							<i class="bi bi-list-ul text-primary me-2"></i>Sản phẩm trong giỏ hàng
						</h5>
					</div>
					<div class="card-body p-0">
						<div class="table-responsive">
							<table class="table table-hover align-middle mb-0">
								<thead class="table-light">
									<tr>
										<th style="width: 40%;" class="ps-4">Sản phẩm</th>
										<th class="text-center" style="width: 20%;">Số lượng</th>
										<th class="text-end" style="width: 15%;">Đơn giá</th>
										<th class="text-end" style="width: 15%;">Thành tiền</th>
										<th class="text-center pe-4" style="width: 10%;"></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var tuple in cartItems ?? new List<(WebsiteDienNha_DoAnChuyenNganh.Models.CartItem, WebsiteDienNha_DoAnChuyenNganh.Models.Product?)>())
									{
										var item = tuple.Item;
										var product = tuple.Product;
										<tr class="cart-item-row">
											<td class="ps-4">
												<div class="d-flex align-items-center">
													@if (product != null && !string.IsNullOrEmpty(product.ImageUrl))
													{
														<div class="product-image-wrapper me-3">
															<img src="@product.ImageUrl" alt="@product.Name" class="product-image">
														</div>
													}
													else
													{
														<div class="product-image-placeholder me-3">
															<i class="bi bi-image"></i>
														</div>
													}
													<div class="flex-grow-1">
														@if (product != null)
														{
															<strong class="d-block mb-1 product-name">@product.Name</strong>
															<a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none small text-primary product-link">
																<i class="bi bi-arrow-right me-1"></i>Xem chi tiết
															</a>
														}
														else
														{
															<span class="text-muted">Sản phẩm #@item.ProductId</span>
														}
													</div>
												</div>
											</td>
											<td>
												<form asp-action="Update" method="post" class="quantity-form d-flex justify-content-center align-items-center">
													<input type="hidden" name="productId" value="@item.ProductId" />
													<div class="quantity-controls">
														<button type="button" class="quantity-btn quantity-decrease" data-product-id="@item.ProductId" title="Giảm số lượng">
															<i class="bi bi-dash-lg"></i>
														</button>
														<input type="number" name="quantity" value="@item.Quantity" min="1" 
														       class="quantity-input text-center" 
														       data-product-id="@item.ProductId" 
														       data-unit-price="@item.UnitPrice" />
														<button type="button" class="quantity-btn quantity-increase" data-product-id="@item.ProductId" title="Tăng số lượng">
															<i class="bi bi-plus-lg"></i>
														</button>
														<button type="submit" class="d-none" title="Cập nhật">
															<i class="bi bi-check"></i>
														</button>
													</div>
												</form>
											</td>
											<td class="text-end">
												<span class="text-muted small d-block mb-1">Đơn giá</span>
												<strong class="unit-price">@item.UnitPrice.ToString("N0") đ</strong>
											</td>
											<td class="text-end">
												<span class="text-muted small d-block mb-1">Thành tiền</span>
												<strong class="text-primary fs-5 fw-bold item-total" data-product-id="@item.ProductId">
													@((item.UnitPrice * item.Quantity).ToString("N0")) đ
												</strong>
											</td>
											<td class="text-center pe-4">
												<form asp-action="Remove" method="post" class="d-inline">
													<input type="hidden" name="productId" value="@item.ProductId" />
													<button type="submit" class="btn btn-sm btn-danger btn-remove rounded-circle" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')" title="Xóa sản phẩm">
														<i class="bi bi-trash"></i>
													</button>
												</form>
											</td>
										</tr>
									}
								</tbody>
								<tfoot>
									<tr class="table-total-row">
										<td colspan="3" class="text-end ps-4 py-4">
											<span class="fs-5 fw-semibold">Tổng cộng:</span>
										</td>
										<td class="text-end py-4">
											<span class="fs-3 fw-bold text-primary" id="cart-total">@(viewBagFinalTotal.ToString("N0")) đ</span>
										</td>
										<td class="pe-4"></td>
									</tr>
								</tfoot>
							</table>
						</div>
					</div>
				</div>

				<!-- Mobile Card View -->
				<div class="d-md-none">
					@foreach (var tuple in cartItems ?? new List<(WebsiteDienNha_DoAnChuyenNganh.Models.CartItem, WebsiteDienNha_DoAnChuyenNganh.Models.Product?)>())
					{
						var item = tuple.Item;
						var product = tuple.Product;
						<div class="card shadow-sm border-0 mb-3 cart-mobile-card">
							<div class="card-body p-3">
								<div class="d-flex align-items-start mb-3">
									@if (product != null && !string.IsNullOrEmpty(product.ImageUrl))
									{
										<div class="product-image-wrapper me-3">
											<img src="@product.ImageUrl" alt="@product.Name" class="product-image">
										</div>
									}
									else
									{
										<div class="product-image-placeholder me-3">
											<i class="bi bi-image"></i>
										</div>
									}
									<div class="flex-grow-1">
										@if (product != null)
										{
											<h6 class="fw-bold mb-1 product-name">@product.Name</h6>
											<a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none small text-primary product-link">
												Xem chi tiết <i class="bi bi-arrow-right"></i>
											</a>
										}
										else
										{
											<span class="text-muted">Sản phẩm #@item.ProductId</span>
										}
									</div>
									<form asp-action="Remove" method="post" class="d-inline">
										<input type="hidden" name="productId" value="@item.ProductId" />
										<button type="submit" class="btn btn-sm btn-danger btn-remove rounded-circle" onclick="return confirm('Xóa sản phẩm?')" title="Xóa">
											<i class="bi bi-trash"></i>
										</button>
									</form>
								</div>
								<hr class="my-3">
								<div class="row g-3">
									<div class="col-6">
										<label class="form-label small text-muted mb-1">Đơn giá</label>
										<p class="mb-0 fw-bold unit-price">@item.UnitPrice.ToString("N0") đ</p>
									</div>
									<div class="col-6 text-end">
										<label class="form-label small text-muted mb-1">Thành tiền</label>
										<p class="mb-0 fw-bold text-primary fs-5 item-total" data-product-id="@item.ProductId">
											@((item.UnitPrice * item.Quantity).ToString("N0")) đ
										</p>
									</div>
									<div class="col-12">
										<form asp-action="Update" method="post" class="quantity-form">
											<input type="hidden" name="productId" value="@item.ProductId" />
											<label class="form-label small text-muted mb-2 fw-semibold">Số lượng</label>
											<div class="quantity-controls">
												<button type="button" class="quantity-btn quantity-decrease" data-product-id="@item.ProductId">
													<i class="bi bi-dash-lg"></i>
												</button>
												<input type="number" name="quantity" value="@item.Quantity" min="1" 
												       class="quantity-input text-center" 
												       data-product-id="@item.ProductId" 
												       data-unit-price="@item.UnitPrice" />
												<button type="button" class="quantity-btn quantity-increase" data-product-id="@item.ProductId">
													<i class="bi bi-plus-lg"></i>
												</button>
												<button type="submit" class="d-none">
													<i class="bi bi-check me-1"></i>Cập nhật
												</button>
											</div>
										</form>
									</div>
								</div>
							</div>
						</div>
					}
				</div>

				<!-- Action Buttons -->
				<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mt-4">
					<a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary btn-lg order-2 order-md-1 rounded-pill">
						<i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
					</a>
					<div class="d-flex flex-column flex-sm-row gap-2 order-1 order-md-2 w-100 w-md-auto">
						<form asp-action="Clear" method="post" class="d-inline flex-fill">
							<button type="submit" class="btn btn-warning btn-lg w-100 rounded-pill" onclick="return confirm('Bạn có chắc muốn xóa tất cả sản phẩm?')">
								<i class="bi bi-x-circle me-2"></i>Xóa giỏ hàng
							</button>
						</form>
						<a asp-action="Checkout" class="btn btn-primary btn-lg w-100 flex-fill rounded-pill">
							<i class="bi bi-cart-check me-2"></i>Thanh toán
						</a>
					</div>
				</div>
			}
		</div>

		<!-- Summary Sidebar -->
		@if (Model.Any())
		{
			<div class="col-12 col-lg-4">
				<div class="card shadow-lg border-0 sticky-top summary-card" style="top: calc(50px + 148px + 50px + 30px); z-index: 998;">
					<div class="card-header bg-primary bg-gradient text-white py-3">
						<h5 class="mb-0 fw-semibold">
							<i class="bi bi-receipt-cutoff me-2"></i>Tóm tắt đơn hàng
						</h5>
					</div>
					<div class="card-body">
						<!-- Discount Code Section -->
						<div class="discount-code-section mb-4">
							<div class="discount-code-header">
								<i class="bi bi-ticket-perforated me-2"></i>
								<span class="fw-semibold">Mã giảm giá</span>
							</div>
							@{
								var appliedDiscountPercent = ViewBag.DiscountPercent as decimal?;
								var appliedDiscountFixed = ViewBag.DiscountFixed as decimal?;
							}
							<div id="discountCodeForm" class="discount-code-form" style="@(hasDiscount ? "display: none;" : "")">
								<div class="input-group discount-input-group">
									<input type="text" class="form-control discount-code-input" id="discountCodeInput" 
									       placeholder="Nhập mã giảm giá" maxlength="50" value="@(hasDiscount ? viewBagAppliedCode : "")">
									<button class="btn discount-apply-btn" type="button" id="applyDiscountBtn" 
									        onclick="event.preventDefault(); event.stopPropagation(); if(typeof handleApplyDiscount === 'function') handleApplyDiscount(); else console.log('handleApplyDiscount not found'); return false;"
									        style="z-index: 10; position: relative; pointer-events: auto !important; cursor: pointer !important;">
										<i class="bi bi-check-lg"></i>
									</button>
								</div>
								<small class="text-muted d-block mt-2">
									<i class="bi bi-info-circle me-1"></i>Nhập mã và nhấn áp dụng
								</small>
							</div>
							<div id="discountCodeApplied" class="discount-applied" style="@(hasDiscount ? "" : "display: none;")">
								<div class="discount-applied-info">
									<div class="d-flex align-items-center justify-content-between mb-2">
										<span class="discount-code-badge">
											<i class="bi bi-ticket-perforated me-1"></i>
											<span id="appliedCodeText">@(viewBagAppliedCode ?? "")</span>
										</span>
										<button class="btn btn-sm btn-link text-danger p-0 remove-discount-btn" id="removeDiscountBtn" type="button">
											<i class="bi bi-x-lg"></i>
										</button>
									</div>
									<div class="discount-amount-display">
										<span class="text-success fw-bold" id="discountAmountDisplay">
											@if (hasDiscount)
											{
												if (appliedDiscountPercent.HasValue)
												{
													<text>-@(appliedDiscountPercent.Value)% (@(viewBagDiscountAmount.ToString("N0")) đ)</text>
												}
												else
												{
													<text>-@(viewBagDiscountAmount.ToString("N0")) đ</text>
												}
											}
										</span>
									</div>
								</div>
							</div>

							<!-- Danh sách mã giảm giá đang còn hiệu lực - Hiển thị tự động khi vượt giá tối thiểu -->
							@{
								var availableCodes = ViewBag.AvailableDiscountCodes as List<WebsiteDienNha_DoAnChuyenNganh.Models.DiscountCode>;
								var hasAvailableCodes = availableCodes != null && availableCodes.Any();
							}
							<div id="availableDiscountCodesContainer" class="mt-3" style="@(hasAvailableCodes ? "display: block;" : "display: none;")">
								<div class="alert alert-success border-0 shadow-sm mb-0" style="background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%); border-left: 4px solid #28a745 !important;">
									<div class="d-flex align-items-start">
										<div class="flex-grow-1">
											<div class="d-flex align-items-center mb-2">
												<i class="bi bi-gift-fill me-2 fs-5 text-success"></i>
												<h6 class="mb-0 fw-bold text-success">🎉 Mã giảm giá khả dụng!</h6>
											</div>
											<div id="availableDiscountCodesList" class="list-group list-group-flush bg-transparent">
												@if (hasAvailableCodes)
												{
													@foreach (var code in availableCodes)
													{
														var daysRemaining = (code.EndDate - DateTime.UtcNow).Days;
														var discountText = "";
														if (code.DiscountPercent.HasValue)
														{
															discountText = $"Giảm {code.DiscountPercent.Value}%";
														}
														else if (code.DiscountAmount.HasValue)
														{
															discountText = $"Giảm {code.DiscountAmount.Value.ToString("N0")} đ";
														}
														var estimatedSavings = 0m;
														if (code.DiscountPercent.HasValue && viewBagCartTotal > 0)
														{
															estimatedSavings = viewBagCartTotal * code.DiscountPercent.Value / 100;
														}
														else if (code.DiscountAmount.HasValue)
														{
															estimatedSavings = code.DiscountAmount.Value;
														}
														
														<div class="list-group-item border-0 px-0 py-2 mb-2 bg-transparent">
															<div class="d-flex justify-content-between align-items-start">
																<div class="flex-grow-1">
																	<div class="d-flex align-items-center mb-1 flex-wrap gap-2">
																		<strong class="text-primary fs-6">@code.Code</strong>
																		<span class="badge bg-success">@discountText</span>
																		@if (estimatedSavings > 0)
																		{
																			<span class="badge bg-warning text-dark">
																				<i class="bi bi-piggy-bank me-1"></i>Tiết kiệm @estimatedSavings.ToString("N0") đ
																			</span>
																		}
																	</div>
																	@if (!string.IsNullOrEmpty(code.Description))
																	{
																		<small class="text-muted d-block mb-1">@code.Description</small>
																	}
																	@if (code.MinimumOrderAmount.HasValue)
																	{
																		<small class="text-muted d-block">
																			<i class="bi bi-info-circle me-1"></i>Áp dụng cho đơn từ @code.MinimumOrderAmount.Value.ToString("N0") đ
																		</small>
																	}
																	<small class="text-muted d-block mt-1">
																		<i class="bi bi-clock me-1"></i>
																		@if (daysRemaining > 0)
																		{
																			<span class="text-success">Còn @daysRemaining ngày</span>
																		}
																		else
																		{
																			<span class="text-warning">Hết hạn hôm nay</span>
																		}
																		<span class="ms-2">(@code.EndDate.ToString("dd/MM/yyyy"))</span>
																	</small>
																</div>
																<button type="button" class="btn btn-sm btn-primary ms-2" onclick="applyDiscountCodeQuick('@code.Code')" title="Áp dụng mã">
																	<i class="bi bi-check-lg me-1"></i>Áp dụng
																</button>
															</div>
														</div>
													}
												}
											</div>
										</div>
										<button type="button" class="btn-close" onclick="document.getElementById('availableDiscountCodesContainer').style.display='none';" aria-label="Đóng"></button>
									</div>
								</div>
							</div>
						</div>

						<div class="summary-item">
							<span class="summary-label">Số loại sản phẩm:</span>
							<strong class="summary-value">@Model.Count()</strong>
						</div>
						<div class="summary-item">
							<span class="summary-label">Tổng số lượng:</span>
							<strong class="summary-value">@Model.Sum(i => i.Quantity) sản phẩm</strong>
						</div>
						<div class="summary-divider"></div>
						@if (hasDiscount)
						{
							<div class="summary-item" id="discountSummaryItem" style="display: flex;">
								<span class="summary-label text-success">
									<i class="bi bi-ticket-perforated me-1"></i>Giảm giá (@viewBagAppliedCode):
								</span>
								<strong class="summary-value text-success" id="discountSummaryAmount">-@(viewBagDiscountAmount.ToString("N0")) đ</strong>
							</div>
						}
						else
						{
							<div class="summary-item" id="discountSummaryItem" style="display: none;">
								<span class="summary-label text-success">
									<i class="bi bi-ticket-perforated me-1"></i>Giảm giá:
								</span>
								<strong class="summary-value text-success" id="discountSummaryAmount">0 đ</strong>
							</div>
						}
						<div class="summary-total">
							<span class="summary-total-label">Tổng cộng:</span>
							<h3 class="summary-total-amount mb-0 text-primary fw-bold" id="summary-total">@(viewBagFinalTotal.ToString("N0")) đ</h3>
						</div>
						<a asp-action="Checkout" class="btn btn-primary btn-lg w-100 rounded-pill mt-4 shadow-sm">
							<i class="bi bi-cart-check me-2"></i>Tiến hành thanh toán
						</a>
						<div class="mt-3">
							<a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary w-100 rounded-pill">
								<i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
							</a>
						</div>
						<div class="alert alert-info small mt-4 mb-0 rounded-pill border-0 shadow-sm">
							<i class="bi bi-truck me-2"></i>
							<strong>Miễn phí vận chuyển</strong> cho đơn hàng trên 500.000 đ
						</div>
					</div>
				</div>
			</div>
		}
	</div>
</div>

<style>
	/* General Styles */
	.empty-cart-card {
		border-radius: 1rem;
		background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
	}
	
	.empty-cart-icon {
		font-size: 8rem;
		color: #dee2e6;
		animation: float 3s ease-in-out infinite;
	}
	
	@@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-20px); }
	}
	
	/* Cart Table Styles */
	.cart-table-card {
		border-radius: 1rem;
		overflow: hidden;
	}
	
	.cart-item-row {
		transition: all 0.3s ease;
		border-bottom: 1px solid #f0f0f0;
	}
	
	.cart-item-row:hover {
		background-color: rgba(13, 110, 253, 0.03);
		transform: translateX(2px);
	}
	
	.table-total-row {
