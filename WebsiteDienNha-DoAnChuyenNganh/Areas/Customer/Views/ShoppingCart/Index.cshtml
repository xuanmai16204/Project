</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		let isUpdating = false;
		let updateQueue = new Set();
		
		// Initialize: Check discount codes on page load
		setTimeout(() => {
			const initialTotal = parseFloat(document.getElementById('summary-total')?.textContent?.replace(/[^\d.]/g, '') || '0');
			if (initialTotal > 0) {
				checkAvailableDiscountCodes(initialTotal);
			}
		}, 1000);
		
		// Function to parse unit price correctly
		function parseUnitPrice(unitPriceStr) {
			if (!unitPriceStr) return 0;
			// Remove any formatting (commas, spaces, currency symbols)
			const cleaned = String(unitPriceStr).replace(/[^\d.]/g, '');
			return parseFloat(cleaned) || 0;
		}
		
		// Function to update totals (client-side only, for immediate feedback)
		function updateTotals() {
			if (isUpdating) return; // Prevent updates during server update
			
			let total = 0;
			const inputs = document.querySelectorAll('.quantity-input');
			
			inputs.forEach(input => {
				const productId = input.dataset.productId;
				// Parse unit price correctly
				const unitPriceStr = input.dataset.unitPrice || '0';
				const unitPrice = parseUnitPrice(unitPriceStr);
				const quantity = parseInt(input.value) || 1;
				
				// Ensure quantity is at least 1
				if (quantity < 1) {
					input.value = 1;
					return;
				}
				
				const itemTotal = unitPrice * quantity;
				
				// Update item total
				const itemTotalElement = document.querySelector(`.item-total[data-product-id="${productId}"]`);
				if (itemTotalElement) {
					itemTotalElement.textContent = Math.round(itemTotal).toLocaleString('vi-VN') + ' đ';
				}
				
				total += itemTotal;
			});
			
			// Update cart total
			const cartTotalElement = document.getElementById('cart-total');
			if (cartTotalElement) {
				cartTotalElement.textContent = Math.round(total).toLocaleString('vi-VN') + ' đ';
			}
			
			// Update summary total
			const summaryTotalElement = document.getElementById('summary-total');
			if (summaryTotalElement) {
				summaryTotalElement.textContent = Math.round(total).toLocaleString('vi-VN') + ' đ';
			}
			
			// Check for new available discount codes when total changes (real-time)
			checkAvailableDiscountCodes(total);
		}
		
		// Function to check available discount codes based on cart total (real-time)
		let lastCheckedTotal = 0;
		let shownDiscountCodes = new Set(); // Track which codes we've already shown
		let checkTimeout = null;
		
		function checkAvailableDiscountCodes(cartTotal) {
			// Debounce: Chỉ check sau 500ms khi người dùng ngừng thay đổi
			if (checkTimeout) {
				clearTimeout(checkTimeout);
			}
			
			checkTimeout = setTimeout(() => {
				// Chỉ check nếu tổng tiền thay đổi đáng kể (ít nhất 500đ) để tránh spam
				if (Math.abs(cartTotal - lastCheckedTotal) < 500 && lastCheckedTotal > 0) {
					return;
				}
				
				lastCheckedTotal = cartTotal;
			
			// Gọi API để lấy danh sách mã giảm giá phù hợp
			fetch('@Url.Action("GetAvailableDiscountCodes", "ShoppingCart", new { area = "Customer" })?cartTotal=' + cartTotal, {
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				}
			})
			.then(response => response.json())
			.then(data => {
				if (data && data.success && data.hasNewCodes && data.availableCodes && data.availableCodes.length > 0) {
					// Lọc ra các mã chưa được hiển thị
					const newCodes = data.availableCodes.filter(code => !shownDiscountCodes.has(code.Id));
					
					if (newCodes.length > 0) {
						// Đánh dấu các mã đã hiển thị
						newCodes.forEach(code => shownDiscountCodes.add(code.Id));
						
						// Hiển thị notification cho mã tốt nhất
						const bestCode = newCodes.reduce((best, current) => {
							return (current.EstimatedSavings || 0) > (best.EstimatedSavings || 0) ? current : best;
						}, newCodes[0]);
						
						// Delay một chút để tránh spam khi người dùng đang thay đổi số lượng
						setTimeout(() => {
							showNewDiscountCodeNotification(bestCode, cartTotal);
						}, 800);
					}
					
					// Cập nhật danh sách mã giảm giá available trong UI
					updateAvailableDiscountCodesList(data.availableCodes);
				}
			})
			.catch(error => {
				console.error('Error checking discount codes:', error);
			});
			}, 500); // Debounce 500ms
		}
		
		// Function to update available discount codes list in UI - Tự động hiển thị khi có mã khả dụng
		function updateAvailableDiscountCodesList(codes) {
			const container = document.getElementById('availableDiscountCodesContainer');
			if (!container) return;
			
			const listGroup = document.getElementById('availableDiscountCodesList');
			if (!listGroup) return;
			
			// Clear existing items
			listGroup.innerHTML = '';
			
			// Nếu có mã giảm giá khả dụng, hiển thị container với animation
			if (codes && codes.length > 0) {
				// Add new codes
				codes.forEach((code, index) => {
					let daysRemaining = 0;
					if (code.EndDate) {
						const endDate = new Date(code.EndDate);
						const now = new Date();
						daysRemaining = Math.ceil((endDate - now) / (1000 * 60 * 60 * 24));
					}
					
					const savings = code.EstimatedSavings || 0;
					const item = document.createElement('div');
					item.className = 'list-group-item border-0 px-0 py-2 mb-2 bg-transparent';
					item.style.cssText = 'animation: slideInLeft 0.4s ease-out ' + (index * 0.1) + 's both;';
					item.innerHTML = `
						<div class="d-flex justify-content-between align-items-start">
							<div class="flex-grow-1">
								<div class="d-flex align-items-center mb-1 flex-wrap gap-2">
									<strong class="text-primary fs-6">${code.Code || ''}</strong>
									<span class="badge bg-success">${code.DiscountText || ''}</span>
									${savings > 0 ? `<span class="badge bg-warning text-dark"><i class="bi bi-piggy-bank me-1"></i>Tiết kiệm ${Math.round(savings).toLocaleString('vi-VN')} đ</span>` : ''}
								</div>
								${code.Description ? `<small class="text-muted d-block mb-1">${code.Description}</small>` : ''}
								${code.MinimumOrderAmount ? `<small class="text-muted d-block"><i class="bi bi-info-circle me-1"></i>Áp dụng cho đơn từ ${parseFloat(code.MinimumOrderAmount).toLocaleString('vi-VN')} đ</small>` : ''}
								${code.EndDate ? `<small class="text-muted d-block mt-1">
									<i class="bi bi-clock me-1"></i>
									${daysRemaining > 0 ? `<span class="text-success">Còn ${daysRemaining} ngày</span>` : '<span class="text-warning">Hết hạn hôm nay</span>'}
									<span class="ms-2">(${new Date(code.EndDate).toLocaleDateString('vi-VN')})</span>
								</small>` : ''}
							</div>
							<button type="button" class="btn btn-sm btn-primary ms-2" onclick="applyDiscountCodeQuick('${code.Code || ''}')" title="Áp dụng mã">
								<i class="bi bi-check-lg me-1"></i>Áp dụng
							</button>
						</div>
					`;
					listGroup.appendChild(item);
				});
				
				// Hiển thị container với animation
				if (container.style.display === 'none' || !container.style.display) {
					container.style.display = 'block';
					container.style.animation = 'slideDown 0.4s ease-out';
				}
			} else {
				// Ẩn container nếu không có mã nào
				container.style.display = 'none';
			}
		}
		
		// Function to show notification when new discount code becomes available
		function showNewDiscountCodeNotification(code, cartTotal) {
			if (!code || !code.Code) return;
			
			// Kiểm tra xem đã hiển thị mã này chưa
			if (shownDiscountCodes.has(code.Id)) {
				return;
			}
			
			const savings = code.EstimatedSavings || 0;
			const discountText = code.DiscountText || '';
			
			// Tạo notification popup
			const alert = document.createElement('div');
			alert.className = 'alert alert-info alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3 shadow-lg';
			alert.style.cssText = 'z-index: 10000; min-width: 400px; max-width: 500px; border-left: 4px solid #0dcaf0; animation: slideDown 0.3s ease-out;';
			alert.innerHTML = `
				<div class="d-flex align-items-start">
					<i class="bi bi-gift-fill me-2 fs-4 text-info"></i>
					<div class="flex-grow-1">
						<h6 class="alert-heading mb-2 fw-bold">🎉 Mã giảm giá mới!</h6>
						<p class="mb-2">Đơn hàng của bạn đã đạt điều kiện cho mã <strong class="text-primary">${code.Code}</strong></p>
						<div class="d-flex align-items-center justify-content-between mb-2">
							<span><i class="bi bi-ticket-perforated me-1"></i><strong>${discountText}</strong></span>
							<span class="badge bg-success">Tiết kiệm ${Math.round(savings).toLocaleString('vi-VN')} đ</span>
						</div>
						${code.MinimumOrderAmount ? `<small class="text-muted d-block mb-2"><i class="bi bi-info-circle me-1"></i>Áp dụng cho đơn từ ${parseFloat(code.MinimumOrderAmount).toLocaleString('vi-VN')} đ</small>` : ''}
						<button type="button" class="btn btn-sm btn-primary mt-2" onclick="applyDiscountCodeQuick('${code.Code}'); this.closest('.alert').remove();">
							<i class="bi bi-check-lg me-1"></i>Áp dụng ngay
						</button>
					</div>
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
				</div>
			`;
			
			document.body.appendChild(alert);
			
			// Đánh dấu đã hiển thị
			if (code.Id) {
				shownDiscountCodes.add(code.Id);
			}
			
			// Auto dismiss after 10 seconds
			setTimeout(() => {
				if (alert.parentNode) {
					alert.classList.remove('show');
					setTimeout(() => alert.remove(), 300);
				}
			}, 10000);
		}
		
		// Update quantity via AJAX
		function updateQuantityOnServer(productId, quantity) {
			// Prevent duplicate updates
			if (updateQueue.has(productId)) {
				return;
			}
			
			updateQueue.add(productId);
			isUpdating = true;
			
			const form = document.querySelector(`.quantity-form input[name="productId"][value="${productId}"]`)?.closest('form');
			if (!form) {
				updateQueue.delete(productId);
				isUpdating = false;
				return;
			}
			
			// Disable buttons during update
			const buttons = form.querySelectorAll('button');
			const input = form.querySelector(`.quantity-input[data-product-id="${productId}"]`);
			buttons.forEach(btn => btn.disabled = true);
			if (input) input.disabled = true;
			
			const formData = new FormData(form);
			formData.set('quantity', quantity);
			
			// Get anti-forgery token
			const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
			if (token) {
				formData.append('__RequestVerificationToken', token);
			}
			
			fetch(form.action, {
				method: 'POST',
				body: formData,
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				}
			}).then(response => {
				if (response.ok) {
					return response.json();
				} else {
					throw new Error('Server error');
				}
			}).then(data => {
				if (data && data.success) {
					// Update UI with server response
					const itemTotalElement = document.querySelector(`.item-total[data-product-id="${productId}"]`);
					if (itemTotalElement) {
						itemTotalElement.textContent = Math.round(data.itemTotal).toLocaleString('vi-VN') + ' đ';
					}
					
					// Update cart total
					const cartTotalElement = document.getElementById('cart-total');
					if (cartTotalElement) {
						cartTotalElement.textContent = Math.round(data.total).toLocaleString('vi-VN') + ' đ';
					}
					
					// Update summary total
					const summaryTotalElement = document.getElementById('summary-total');
					if (summaryTotalElement) {
						summaryTotalElement.textContent = Math.round(data.total).toLocaleString('vi-VN') + ' đ';
					}
					
					// Check for new available discount codes (real-time)
					checkAvailableDiscountCodes(data.total);
					
					// Also check from server response if available
					if (data.availableDiscountCodes && data.availableDiscountCodes.length > 0 && data.hasBetterDiscount) {
						// Delay notification a bit to avoid spam
						setTimeout(function() {
							showNewDiscountCodesNotification(data.availableDiscountCodes, data.total);
						}, 500);
					}
					
					// Re-enable controls
					buttons.forEach(btn => btn.disabled = false);
					if (input) input.disabled = false;
					updateQueue.delete(productId);
					isUpdating = false;
				} else {
					throw new Error('Update failed');
				}
			}).catch(error => {
				buttons.forEach(btn => btn.disabled = false);
				if (input) input.disabled = false;
				updateQueue.delete(productId);
				isUpdating = false;
				console.error('Error updating quantity:', error);
				
				// If JSON parsing fails, it might be a redirect, so reload
				if (error instanceof SyntaxError) {
					window.location.reload();
				} else {
					alert('Có lỗi xảy ra khi cập nhật số lượng. Vui lòng thử lại.');
					// Recalculate totals on error
					updateTotals();
				}
			});
		}
		
		// Quantity input change
		document.querySelectorAll('.quantity-input').forEach(input => {
			let timeout;
			
			input.addEventListener('change', function() {
				const quantity = parseInt(this.value) || 1;
				if (quantity < 1) {
					this.value = 1;
					updateTotals();
					return;
				}
				
				// Update totals immediately
				updateTotals();
				
				// Debounce: Update server after 1 second of no changes
				clearTimeout(timeout);
				timeout = setTimeout(() => {
					if (!isUpdating) {
						updateQuantityOnServer(this.dataset.productId, quantity);
					}
				}, 1000);
			});
			
			input.addEventListener('input', function() {
				// Update totals in real-time as user types (but don't update server yet)
				if (!isUpdating) {
					updateTotals();
				}
			});
		});
		
		// Decrease button
		document.querySelectorAll('.quantity-decrease').forEach(btn => {
			btn.addEventListener('click', function() {
				if (isUpdating) return;
				
				const productId = this.dataset.productId;
				const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`);
				if (input && !input.disabled) {
					const currentValue = parseInt(input.value) || 1;
					if (currentValue > 1) {
						const newValue = currentValue - 1;
						input.value = newValue;
						// Update UI immediately
						updateTotals();
						// Then update server immediately (no delay for button clicks)
						updateQuantityOnServer(productId, newValue);
					}
				}
			});
		});
		
		// Increase button
		document.querySelectorAll('.quantity-increase').forEach(btn => {
			btn.addEventListener('click', function() {
				if (isUpdating) return;
				
				const productId = this.dataset.productId;
				const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`);
				if (input && !input.disabled) {
					const currentValue = parseInt(input.value) || 1;
					const newValue = currentValue + 1;
					input.value = newValue;
					// Update UI immediately
					updateTotals();
					// Then update server immediately (no delay for button clicks)
					updateQuantityOnServer(productId, newValue);
				}
			});
		});
	});

	// Discount Code Functionality - Sử dụng cả vanilla JS và jQuery để đảm bảo hoạt động
	function initDiscountCode() {
		const applyDiscountBtn = document.getElementById('applyDiscountBtn');
		const removeDiscountBtn = document.getElementById('removeDiscountBtn');
		const discountCodeInput = document.getElementById('discountCodeInput');
		const discountCodeForm = document.getElementById('discountCodeForm');
		const discountCodeApplied = document.getElementById('discountCodeApplied');
		const appliedCodeText = document.getElementById('appliedCodeText');
		const discountAmountDisplay = document.getElementById('discountAmountDisplay');
		const discountSummaryItem = document.getElementById('discountSummaryItem');
		const discountSummaryAmount = document.getElementById('discountSummaryAmount');

		if (!applyDiscountBtn || !discountCodeInput) {
			console.warn('Discount code elements not found, retrying...');
			setTimeout(initDiscountCode, 100);
			return;
		}

		console.log('Discount code elements found, initializing...');

		function showDiscountNotification(message, type) {
			const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
			const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
			const alert = $('<div class="alert ' + alertClass + ' alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; min-width: 300px;">' +
				'<div class="d-flex align-items-center">' +
				'<i class="bi ' + icon + ' me-2 fs-5"></i>' +
				'<div class="flex-grow-1">' + message + '</div>' +
				'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
				'</div></div>');
			$('body').append(alert);
			setTimeout(function () {
				alert.alert('close');
			}, 3000);
		}

		function showNewDiscountCodesNotification(codes, cartTotal) {
			if (!codes || codes.length === 0) return;
			
			// Tìm mã giảm giá tốt nhất (giảm nhiều nhất)
			const bestCode = codes.reduce((best, current) => {
				const currentDiscount = current.discountPercent 
					? (cartTotal * current.discountPercent / 100)
					: (current.discountAmount || 0);
				const bestDiscount = best.discountPercent 
					? (cartTotal * best.discountPercent / 100)
					: (best.discountAmount || 0);
				return currentDiscount > bestDiscount ? current : best;
			}, codes[0]);
			
			// Tính số tiền tiết kiệm
			const savings = bestCode.discountPercent 
				? (cartTotal * bestCode.discountPercent / 100)
				: (bestCode.discountAmount || 0);
			
			// Đánh dấu mã đã hiển thị
			if (bestCode.id) {
				shownDiscountCodes.add(bestCode.id);
			}
			
			// Tạo notification
			const alert = $('<div class="alert alert-info alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3 shadow-lg" style="z-index: 10000; min-width: 400px; max-width: 500px; border-left: 4px solid #0dcaf0;">' +
				'<div class="d-flex align-items-start">' +
				'<i class="bi bi-gift-fill me-2 fs-4 text-info"></i>' +
				'<div class="flex-grow-1">' +
				'<h6 class="alert-heading mb-2 fw-bold">🎉 Bạn có thể tiết kiệm thêm!</h6>' +
				'<p class="mb-2">Đơn hàng của bạn đã đạt điều kiện cho mã giảm giá <strong class="text-primary">' + bestCode.code + '</strong></p>' +
				'<div class="d-flex align-items-center justify-content-between mb-2">' +
				'<span><i class="bi bi-ticket-perforated me-1"></i><strong>' + bestCode.discountText + '</strong></span>' +
				'<span class="badge bg-success">Tiết kiệm ' + Math.round(savings).toLocaleString('vi-VN') + ' đ</span>' +
				'</div>' +
				'<button type="button" class="btn btn-sm btn-primary mt-2" onclick="applyDiscountCodeQuick(\'' + bestCode.code + '\')">' +
				'<i class="bi bi-check-lg me-1"></i>Áp dụng ngay</button>' +
				'</div>' +
				'<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
				'</div></div>');
			
			$('body').append(alert);
			
			// Auto dismiss after 10 seconds
			setTimeout(function () {
				alert.alert('close');
			}, 10000);
		}

		// Function to quickly apply discount code
		window.applyDiscountCodeQuick = function(code) {
			const input = document.getElementById('discountCodeInput');
			const btn = document.getElementById('applyDiscountBtn');
			if (input && btn) {
				input.value = code;
				if (typeof handleApplyDiscount === 'function') {
					handleApplyDiscount();
				} else if (btn.onclick) {
					btn.click();
				}
			}
		};

		// Đảm bảo button không bị disable
		applyDiscountBtn.disabled = false;
		applyDiscountBtn.style.pointerEvents = 'auto';
		applyDiscountBtn.style.cursor = 'pointer';

		// Remove existing event listeners bằng cách clone button
		const newApplyBtn = applyDiscountBtn.cloneNode(true);
		applyDiscountBtn.parentNode.replaceChild(newApplyBtn, applyDiscountBtn);
		const applyBtn = document.getElementById('applyDiscountBtn');

		// Attach event listener nhiều cách để đảm bảo hoạt động
		applyBtn.addEventListener('click', function(e) {
			e.preventDefault();
			e.stopPropagation();
			handleApplyDiscount();
		});

		// Dùng jQuery nếu có
		if (typeof $ !== 'undefined') {
			$(applyBtn).off('click').on('click', function(e) {
				e.preventDefault();
				e.stopPropagation();
				handleApplyDiscount();
			});
		}

		// Make function global để có thể gọi từ inline onclick
		window.handleApplyDiscount = function() {
			const code = discountCodeInput.value.trim().toUpperCase();
			if (!code) {
				showDiscountNotification('Vui lòng nhập mã giảm giá', 'error');
				return;
			}

			console.log('Applying discount code:', code);
			applyBtn.disabled = true;
			applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
			applyBtn.style.pointerEvents = 'none';

				$.ajax({
					url: '@Url.Action("ApplyDiscountCode", "ShoppingCart", new { area = "Customer" })',
					type: 'POST',
					contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
					data: { 
						discountCode: code
					},
				success: function(response) {
					console.log('Discount code response:', response);
					if (response && response.success) {
						// Hide form, show applied
						if (discountCodeForm) discountCodeForm.style.display = 'none';
						if (discountCodeApplied) discountCodeApplied.style.display = 'block';
						
						if (appliedCodeText) appliedCodeText.textContent = response.code;
						
						// Display discount amount
						let discountText = '';
						if (response.discountPercent) {
							discountText = `-${response.discountPercent}% (${Math.round(response.discountAmount).toLocaleString('vi-VN')} đ)`;
						} else {
							discountText = `-${Math.round(response.discountAmount).toLocaleString('vi-VN')} đ`;
						}
						if (discountAmountDisplay) discountAmountDisplay.textContent = discountText;
						
						// Update summary
						if (discountSummaryItem) discountSummaryItem.style.display = 'flex';
						if (discountSummaryAmount) discountSummaryAmount.textContent = `-${Math.round(response.discountAmount).toLocaleString('vi-VN')} đ`;
						
						// Update total in summary sidebar
						const summaryTotal = document.getElementById('summary-total');
						if (summaryTotal) {
							summaryTotal.textContent = Math.round(response.finalTotal).toLocaleString('vi-VN') + ' đ';
						}
						
						// Update total in table footer
						const cartTotalElement = document.getElementById('cart-total');
						if (cartTotalElement) {
							cartTotalElement.textContent = Math.round(response.finalTotal).toLocaleString('vi-VN') + ' đ';
						}
						
						showDiscountNotification(response.message || 'Áp dụng mã giảm giá thành công!', 'success');
						
						// KHÔNG reload trang nữa, chỉ cập nhật UI
					} else {
						showDiscountNotification(response?.message || 'Không thể áp dụng mã giảm giá', 'error');
						applyBtn.disabled = false;
						applyBtn.innerHTML = '<i class="bi bi-check-lg"></i>';
						applyBtn.style.pointerEvents = 'auto';
					}
				},
				error: function(xhr, status, error) {
					console.error('Error applying discount code:', error);
					console.error('Status:', status);
					console.error('Response:', xhr.responseText);
					let errorMessage = 'Có lỗi xảy ra khi áp dụng mã giảm giá';
					if (xhr.responseJSON && xhr.responseJSON.message) {
						errorMessage = xhr.responseJSON.message;
					} else if (xhr.status === 401) {
						errorMessage = 'Vui lòng đăng nhập để sử dụng mã giảm giá';
					} else if (xhr.status === 400) {
						errorMessage = 'Mã giảm giá không hợp lệ';
					} else if (xhr.status === 0) {
						errorMessage = 'Không thể kết nối đến server. Vui lòng kiểm tra kết nối mạng.';
					}
					showDiscountNotification(errorMessage, 'error');
					applyBtn.disabled = false;
					applyBtn.innerHTML = '<i class="bi bi-check-lg"></i>';
					applyBtn.style.pointerEvents = 'auto';
				}
			});
		};

		// Allow Enter key to apply
		if (discountCodeInput) {
			discountCodeInput.addEventListener('keypress', function(e) {
				if (e.key === 'Enter' || e.keyCode === 13) {
					e.preventDefault();
					e.stopPropagation();
					handleApplyDiscount();
				}
			});
		}

		// Remove discount code handler
		if (removeDiscountBtn) {
			removeDiscountBtn.addEventListener('click', function(e) {
				e.preventDefault();
				e.stopPropagation();
				handleRemoveDiscount();
			});
		}

		function handleRemoveDiscount() {
			$.ajax({
				url: '@Url.Action("RemoveDiscountCode", "ShoppingCart", new { area = "Customer" })',
				type: 'POST',
				success: function(response) {
					if (response && response.success) {
						// Show form, hide applied
						if (discountCodeForm) discountCodeForm.style.display = 'block';
						if (discountCodeApplied) discountCodeApplied.style.display = 'none';
						if (discountCodeInput) discountCodeInput.value = '';
						
						// Hide discount summary
						if (discountSummaryItem) discountSummaryItem.style.display = 'none';
						
						// Update total in summary sidebar
						const summaryTotal = document.getElementById('summary-total');
						if (summaryTotal && response.finalTotal) {
							summaryTotal.textContent = Math.round(response.finalTotal).toLocaleString('vi-VN') + ' đ';
						}
						
						// Update total in table footer
						const cartTotalElement = document.getElementById('cart-total');
						if (cartTotalElement && response.finalTotal) {
							cartTotalElement.textContent = Math.round(response.finalTotal).toLocaleString('vi-VN') + ' đ';
						}
						
						showDiscountNotification(response.message || 'Đã xóa mã giảm giá', 'success');
						
						// KHÔNG reload trang nữa, chỉ cập nhật UI
					}
				},
				error: function(xhr, status, error) {
					console.error('Error removing discount code:', error);
					showDiscountNotification('Có lỗi xảy ra khi xóa mã giảm giá', 'error');
				}
			});
		}
	}

	// Initialize discount code functionality - thử nhiều cách để đảm bảo hoạt động
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDiscountCode);
	} else {
		initDiscountCode();
	}

	// Dùng jQuery nếu có
	if (typeof jQuery !== 'undefined') {
		jQuery(document).ready(function($) {
			initDiscountCode();
		});
	}

	// Fallback: thử lại sau 500ms
	setTimeout(function() {
		const btn = document.getElementById('applyDiscountBtn');
		if (btn && !btn.hasAttribute('data-initialized')) {
			console.log('Retrying discount code initialization...');
			btn.setAttribute('data-initialized', 'true');
			initDiscountCode();
		}
	}, 500);
</script>


