@model WebsiteDienNha_DoAnChuyenNganh.Models.Product
@{
	ViewData["Title"] = "Sửa sản phẩm";
}

<div class="container my-4">
	<div class="row justify-content-center">
		<div class="col-12 col-lg-10">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-warning text-dark">
					<h4 class="mb-0 fw-bold"><i class="bi bi-pencil me-2"></i>Sửa sản phẩm</h4>
				</div>
				<div class="card-body p-4">
					<form asp-action="Edit" method="post" enctype="multipart/form-data">
						<input type="hidden" asp-for="Id" />
						<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
						<div class="row g-3">
							<div class="col-12 col-md-6">
								<label asp-for="Name" class="form-label fw-semibold"></label>
								<input asp-for="Name" class="form-control form-control-lg" placeholder="Tên sản phẩm" />
								<span asp-validation-for="Name" class="text-danger small"></span>
							</div>
							<div class="col-12 col-md-6">
								<label asp-for="CategoryId" class="form-label fw-semibold"></label>
								<select asp-for="CategoryId" class="form-select form-select-lg" asp-items="ViewBag.CategoryId">
									<option value="">Chọn danh mục</option>
								</select>
							</div>
						<div class="col-12 col-md-6">
							<label asp-for="Price" class="form-label fw-semibold">Giá gốc</label>
							<input asp-for="Price" class="form-control form-control-lg" type="number" step="0.01" placeholder="0" />
							<span asp-validation-for="Price" class="text-danger small"></span>
						</div>
						<div class="col-12 col-md-6">
							<label asp-for="PromotionPrice" class="form-label fw-semibold">Giá khuyến mãi (tùy chọn)</label>
							<input asp-for="PromotionPrice" class="form-control form-control-lg" type="number" step="0.01" placeholder="Để trống nếu không có" />
							<small class="text-muted">Nếu để trống, hệ thống sẽ tự động tính từ Promotion</small>
							<span asp-validation-for="PromotionPrice" class="text-danger small"></span>
						</div>
						<div class="col-12 col-md-6">
							<label asp-for="Stock" class="form-label fw-semibold"></label>
							<input asp-for="Stock" class="form-control form-control-lg" type="number" placeholder="0" />
						</div>
							<div class="col-12 col-md-6">
								<label asp-for="Slug" class="form-label fw-semibold"></label>
								<input asp-for="Slug" class="form-control form-control-lg" placeholder="slug-san-pham" />
								<small class="text-muted">URL-friendly identifier</small>
							</div>
							<div class="col-12 col-md-6">
								<label class="form-label fw-semibold">Hình ảnh sản phẩm</label>
								<input type="file" name="imageFile" class="form-control form-control-lg" accept="image/*" />
								<small class="text-muted">Chọn file ảnh mới để thay thế (JPG, PNG, GIF)</small>
								@if (!string.IsNullOrEmpty(Model.ImageUrl))
								{
									<div class="mt-2">
										<label class="form-label fw-semibold">Ảnh hiện tại:</label>
										<div>
											<img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-width: 200px; max-height: 200px;" />
										</div>
									</div>
								}
								<div id="imagePreview" class="mt-2" style="display: none;">
									<label class="form-label fw-semibold">Ảnh mới:</label>
									<img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px; max-height: 200px;" />
								</div>
							</div>
							<div class="col-12">
								<label asp-for="ImageUrl" class="form-label fw-semibold">Hoặc nhập URL hình ảnh</label>
								<input asp-for="ImageUrl" class="form-control form-control-lg" placeholder="https://example.com/image.jpg" />
								<small class="text-muted">Nếu không upload file, có thể nhập URL trực tiếp</small>
							</div>
							<div class="col-12">
								<label asp-for="Description" class="form-label fw-semibold"></label>
								<textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả sản phẩm"></textarea>
							</div>
							<div class="col-12">
								<div class="form-check">
									<input asp-for="IsActive" class="form-check-input" />
									<label asp-for="IsActive" class="form-check-label fw-semibold">Kích hoạt</label>
								</div>
							</div>
						</div>
						<div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
							<a asp-action="Index" class="btn btn-outline-secondary btn-lg">
								<i class="bi bi-arrow-left me-2"></i>Quay lại
							</a>
							<button type="submit" class="btn btn-warning btn-lg">
								<i class="bi bi-save me-2"></i>Lưu thay đổi
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

<partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />

<script>
	document.querySelector('input[name="imageFile"]').addEventListener('change', function(e) {
		const file = e.target.files[0];
		if (file) {
			const reader = new FileReader();
			reader.onload = function(e) {
				document.getElementById('previewImg').src = e.target.result;
				document.getElementById('imagePreview').style.display = 'block';
			}
			reader.readAsDataURL(file);
		} else {
			document.getElementById('imagePreview').style.display = 'none';
		}
	});
</script>


