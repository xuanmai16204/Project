@model WebsiteDienNha_DoAnChuyenNganh.Models.Product
@{
	ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container my-4">
	<div class="row">
		<div class="col-12 col-lg-6 mb-4 mb-lg-0">
			<div class="card shadow-sm border-0 h-100">
				@if (!string.IsNullOrEmpty(Model.ImageUrl))
				{
					<img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name" style="max-height: 400px; object-fit: contain;">
				}
				else
				{
					<div class="bg-light d-flex align-items-center justify-content-center" style="height: 400px;">
						<i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
					</div>
				}
			</div>
		</div>
		<div class="col-12 col-lg-6">
			<div class="card shadow-sm border-0 h-100">
				<div class="card-header bg-info text-white">
					<h4 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Chi tiết sản phẩm</h4>
				</div>
				<div class="card-body p-4">
					<div class="row g-3">
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-box-seam me-2"></i>Tên sản phẩm:</strong></p>
								<h5 class="mb-0">@Model.Name</h5>
							</div>
						</div>
						<div class="col-12 col-md-6">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-tag me-2"></i>Danh mục:</strong></p>
								<p class="mb-0"><span class="badge bg-secondary">@Model.Category?.Name</span></p>
							</div>
						</div>
						<div class="col-12 col-md-6">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-currency-dollar me-2"></i>Giá:</strong></p>
								<p class="mb-0"><strong class="text-primary fs-5">@Model.Price.ToString("N0") đ</strong></p>
							</div>
						</div>
						<div class="col-12 col-md-6">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-box me-2"></i>Tồn kho:</strong></p>
								<p class="mb-0">
									@if (Model.Stock > 0)
									{
										<span class="badge bg-success fs-6">@Model.Stock sản phẩm</span>
									}
									else
									{
										<span class="badge bg-danger fs-6">Hết hàng</span>
									}
								</p>
							</div>
						</div>
						<div class="col-12 col-md-6">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-toggle-on me-2"></i>Trạng thái:</strong></p>
								<p class="mb-0">
									@if (Model.IsActive)
									{
										<span class="badge bg-success fs-6">
											<i class="bi bi-check-circle me-1"></i>Đang kích hoạt
										</span>
									}
									else
									{
										<span class="badge bg-danger fs-6">
											<i class="bi bi-x-circle me-1"></i>Đã tắt
										</span>
									}
								</p>
							</div>
						</div>
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-link me-2"></i>Slug:</strong></p>
								<code class="fs-6">@Model.Slug</code>
							</div>
						</div>
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-file-text me-2"></i>Mô tả:</strong></p>
								<p class="mb-0 text-muted">@(Model.Description ?? "Không có mô tả")</p>
							</div>
						</div>
					</div>
					<div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
						<a asp-action="Index" class="btn btn-outline-secondary btn-lg">
							<i class="bi bi-arrow-left me-2"></i>Quay lại
						</a>
						<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg">
							<i class="bi bi-pencil me-2"></i>Sửa
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>


