@model WebsiteDienNha_DoAnChuyenNganh.Models.Product
@{
	ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container my-4">
	<div class="row justify-content-center">
		<div class="col-12 col-lg-8">
			<div class="card shadow-sm border-0 border-danger">
				<div class="card-header bg-danger text-white">
					<h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Xóa sản phẩm</h4>
				</div>
				<div class="card-body p-4">
					<div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
						<i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
						<div>
							<strong>Bạn có chắc chắn muốn xóa sản phẩm này?</strong>
							<p class="mb-0 small">Hành động này không thể hoàn tác.</p>
						</div>
					</div>

					<div class="row g-3 mb-4">
						@if (!string.IsNullOrEmpty(Model.ImageUrl))
						{
							<div class="col-12 col-md-4">
								<div class="card">
									<img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name" style="height: 200px; object-fit: cover;">
								</div>
							</div>
						}
						<div class="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "col-12 col-md-8" : "col-12")">
							<div class="card bg-light h-100">
								<div class="card-body">
									<dl class="row mb-0">
										<dt class="col-sm-4"><i class="bi bi-box-seam me-2"></i>Tên sản phẩm:</dt>
										<dd class="col-sm-8"><strong>@Model.Name</strong></dd>
										<dt class="col-sm-4"><i class="bi bi-tag me-2"></i>Danh mục:</dt>
										<dd class="col-sm-8"><span class="badge bg-secondary">@Model.Category?.Name</span></dd>
										<dt class="col-sm-4"><i class="bi bi-currency-dollar me-2"></i>Giá:</dt>
										<dd class="col-sm-8"><strong class="text-primary">@Model.Price.ToString("N0") đ</strong></dd>
										<dt class="col-sm-4"><i class="bi bi-box me-2"></i>Tồn kho:</dt>
										<dd class="col-sm-8">
											@if (Model.Stock > 0)
											{
												<span class="badge bg-success">@Model.Stock</span>
											}
											else
											{
												<span class="badge bg-danger">0</span>
											}
										</dd>
									</dl>
								</div>
							</div>
						</div>
					</div>

					<form asp-action="Delete" method="post">
						<input type="hidden" asp-for="Id" />
						<div class="d-grid gap-2 d-md-flex justify-content-md-end">
							<a asp-action="Index" class="btn btn-outline-secondary btn-lg">
								<i class="bi bi-x-circle me-2"></i>Hủy
							</a>
							<button type="submit" class="btn btn-danger btn-lg">
								<i class="bi bi-trash me-2"></i>Xóa vĩnh viễn
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>


