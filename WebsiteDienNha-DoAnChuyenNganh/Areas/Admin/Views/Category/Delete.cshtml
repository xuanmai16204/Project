@model WebsiteDienNha_DoAnChuyenNganh.Models.Category
@{
	ViewData["Title"] = "Xóa danh mục";
}

<div class="container my-4">
	<div class="row justify-content-center">
		<div class="col-12 col-lg-8">
			<div class="card shadow-sm border-0 border-danger">
				<div class="card-header bg-danger text-white">
					<h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Xóa danh mục</h4>
				</div>
				<div class="card-body p-4">
					<div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
						<i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
						<div>
							<strong>Bạn có chắc chắn muốn xóa danh mục này?</strong>
							<p class="mb-0 small">Hành động này không thể hoàn tác.</p>
						</div>
					</div>

					<div class="card bg-light mb-4">
						<div class="card-body">
							<dl class="row mb-0">
								<dt class="col-sm-4"><i class="bi bi-tag me-2"></i>Tên danh mục:</dt>
								<dd class="col-sm-8"><strong>@Model.Name</strong></dd>
								<dt class="col-sm-4"><i class="bi bi-link me-2"></i>Slug:</dt>
								<dd class="col-sm-8"><code>@Model.Slug</code></dd>
							</dl>
						</div>
					</div>

					<form asp-action="Delete" method="post">
						<input type="hidden" asp-for="Id" />
						<div class="d-grid gap-2 d-md-flex justify-content-md-end">
							<a asp-action="Index" class="btn btn-outline-secondary btn-lg">
								<i class="bi bi-x-circle me-2"></i>Hủy
							</a>
							<button type="submit" class="btn btn-danger btn-lg">
								<i class="bi bi-trash me-2"></i>Xóa vĩnh viễn
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>


