@model WebsiteDienNha_DoAnChuyenNganh.Models.Category
@{
	ViewData["Title"] = "Chi tiết danh mục";
}

<div class="container my-4">
	<div class="row justify-content-center">
		<div class="col-12 col-lg-8">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-info text-white">
					<h4 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Chi tiết danh mục</h4>
				</div>
				<div class="card-body p-4">
					<div class="row g-4">
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-tag me-2"></i>Tên danh mục:</strong></p>
								<h5 class="mb-0">@Model.Name</h5>
							</div>
						</div>
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-link me-2"></i>Slug:</strong></p>
								<code class="fs-6">@Model.Slug</code>
							</div>
						</div>
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-file-text me-2"></i>Mô tả:</strong></p>
								<p class="mb-0 text-muted">@(Model.Description ?? "Không có mô tả")</p>
							</div>
						</div>
						<div class="col-12">
							<div class="p-3 bg-light rounded">
								<p class="mb-2"><strong><i class="bi bi-toggle-on me-2"></i>Trạng thái:</strong></p>
								<p class="mb-0">
									@if (Model.IsActive)
									{
										<span class="badge bg-success fs-6">
											<i class="bi bi-check-circle me-1"></i>Đang kích hoạt
										</span>
									}
									else
									{
										<span class="badge bg-danger fs-6">
											<i class="bi bi-x-circle me-1"></i>Đã tắt
										</span>
									}
								</p>
							</div>
						</div>
					</div>
					<div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
						<a asp-action="Index" class="btn btn-outline-secondary btn-lg">
							<i class="bi bi-arrow-left me-2"></i>Quay lại
						</a>
						<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg">
							<i class="bi bi-pencil me-2"></i>Sửa
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>


