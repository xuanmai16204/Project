@model IEnumerable<WebsiteDienNha_DoAnChuyenNganh.Models.Category>
@{
	ViewData["Title"] = "Quản lý danh mục";
}

<div class="container my-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="fw-bold mb-0"><i class="bi bi-tags me-2 text-primary"></i>Quản lý danh mục</h2>
		<a asp-action="Create" class="btn btn-primary btn-lg">
			<i class="bi bi-plus-circle me-2"></i>Tạo mới
		</a>
	</div>

	<div class="card shadow-sm border-0">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th>Tên danh mục</th>
							<th>Slug</th>
							<th class="text-center">Thao tác</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							<tr>
								<td><strong>@item.Name</strong></td>
								<td><code class="text-muted">@item.Slug</code></td>
								<td class="text-center">
									<div class="btn-group" role="group">
										<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
											<i class="bi bi-pencil me-1"></i>Sửa
										</a>
										<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
											<i class="bi bi-eye me-1"></i>Chi tiết
										</a>
										<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
											<i class="bi bi-trash me-1"></i>Xóa
										</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>


